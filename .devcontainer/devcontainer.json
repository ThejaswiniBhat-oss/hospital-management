{
  "name": "Hospital Management (Java + Swing + MySQL)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": true
    },
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vscode",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },

  "containerEnv": { "DISPLAY": ":1" },

  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": { "label": "Desktop (open this to see the Swing app)" }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "sudo service mysql start",

  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack"]
    }
  },

  "remoteUser": "vscode"
}
